{
  "name": "hoekens-anchor-alarm",
  "version": "2.0.0",
  "description": "Web app based anchor alarm with scope calculator, scribble tracks, engine override, and physically accurate icons.",
  "main": "index.js",
  "scripts": {
    "test": "$NODE $npm_package_main",
    "release": "git tag -d v$npm_package_version; git tag v$npm_package_version && git push --tags && git push && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "eslint --fix . && prettier --write .",
    "format:check": "eslint . && prettier --check .",
    "prepare": "husky",
    "build:ui": "vite build",
    "prepublishOnly": "npm run build:ui"
  },
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{json,css,html}": "prettier --write"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp"
  ],
  "signalk": {
    "appIcon": "anchoralarm.png",
    "displayName": "Hoeken's Anchor Alarm"
  },
  "author": {
    "name": "Zach Hoeken",
    "email": "hoeken@gmail.com"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@signalk/client": "^2.4.0",
    "@signalk/tracks-plugin": "^2.0.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoeken/hoekens-anchor-alarm.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.13"
  }
}
