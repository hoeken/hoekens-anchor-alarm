{
  "name": "hoekens-anchor-alarm",
  "version": "2.3.0",
  "description": "Anchor alarm with various shapes, scope calculator, scribble tracks, engine override, and physically accurate icons.",
  "main": "src/index.cjs",
  "type": "module",
  "scripts": {
    "test": "echo \"no tests — Signal K plugin CI validates lifecycle and schema\" && exit 0",
    "release": "git tag -d v$npm_package_version; git tag v$npm_package_version && git push --tags && git push && npm publish",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "eslint --fix . && prettier --write .",
    "format:check": "eslint . && prettier --check .",
    "postinstall": "node -e \"try{if(!process.env.CI&&require('fs').existsSync('.git'))require('husky')()}catch(e){}\"",
    "build:ui": "vite build",
    "prepack": "npm run build:ui"
  },
  "files": [
    "src",
    "shared",
    "public"
  ],
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{json,css,html}": "prettier --write"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp"
  ],
  "signalk": {
    "appIcon": "anchoralarm.png",
    "displayName": "Hoeken's Anchor Alarm"
  },
  "author": {
    "name": "Zach Hoeken",
    "email": "hoeken@gmail.com"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19"
  },
  "dependencies": {
    "@signalk/client": "^2.4.0",
    "@signalk/tracks-plugin": "^2.0.2",
    "@turf/turf": "^7.3.5",
    "d3": "^7.9.0",
    "mathjs": "^15.2.0",
    "simplify-js": "^1.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoeken/hoekens-anchor-alarm.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "vite": "^8.0.13"
  }
}
